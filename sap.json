{
  "schema": "sa.plugin/1",
  "name": "bc2sa",
  "version": "0.1.0",
  "source": {
    "type": "local",
    "path": "."
  },
  "abi": {
    "plugin": 1,
    "saasm": ">=0.4.0"
  },
  "artifacts": {
    "linux-x86_64": {
      "path": "zig-out/lib/libbc2sa.so"
    }
  },
  "interfaces": {},
  "skills": ["bc2sa"],
  "permissions": {
    "fs": [
      { "op": "read", "path": "$PROJECT/**" }
    ],
    "net": [],
    "env": ["HOME", "SA_*"],
    "process": {
      "spawn": true,
      "exec": [
        {
          "path": "/usr/bin/llvm-dis-14",
          "args": ["-o", "-", "*"]
        }
      ]
    }
  },
  "dependencies": {}
}
